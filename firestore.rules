rules_version = '2';
// ─────────────────────────────────────────────────────────────────────────────
// Paste this into Firebase Console → Firestore → Rules
// OR run:  firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can READ user profiles (required for leaderboard
      // and friend search — we never expose sensitive fields in the UI).
      allow get:  if request.auth != null;
      allow list: if request.auth != null;

      // Only the account owner can write their own document.
      allow create, update, delete: if request.auth != null
                                    && request.auth.uid == userId;

      // Word bank — private to owner only
      match /wordBank/{termId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // Quiz sessions — private to owner only
      match /quizSessions/{sessionId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ── Username uniqueness index ──────────────────────────────────────────
    // Anyone authenticated can check if a username is taken (read).
    // Only the UID stored in the doc can claim/release it (write).
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      // No updates — delete + create instead (atomic via transaction)
    }

    // ── Terms dictionary ──────────────────────────────────────────────────
    // Publicly readable; any authenticated user can add a new term (AI save).
    match /terms/{termId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── App metadata (word of the day etc.) ───────────────────────────────
    match /meta/{docId} {
      allow read: if true;
      allow write: if false; // Admin SDK / Firebase Console only
    }
  }
}
